# ====================================================================
# Gitignore Optimization (Security First)
# ====================================================================

# 1. Credentials & Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.jks
*.p8
*.p12
*.mobileprovision
*.keystore
credentials.json
client_secret.json

# 2. Local Databases
*.sqlite
*.sqlite3
*.db

# 3. Dependencies
node_modules/
venv/
.venv/
__pycache__/
*.pyc

# 4. Expo & React Native Build Outputs
.expo/
dist/
build/
web-build/
expo-env.d.ts
/app/ios/
/app/android/
.kotlin/
*.orig.*

# 5. Logs & Temporary Files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.metro-health-check*
.eslintcache
*.tsbuildinfo

# 6. IDE & System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.idea/
.vscode/
*.swp
*.swo
